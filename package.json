{
  "name": "gulgle-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts"
  ],
  "scripts": {
    "biome:check": "biome check .",
    "biome:write": "biome check . --write",
    "biome:ci": "biome ci .",
    "typecheck": "pnpm -r typecheck",
    "update-bangs": "tsx ./scripts/update-bangs.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@types/node": "^24.9.1",
    "tsx": "^4.22.0",
    "typescript": "~5.7.3"
  },
  "packageManager": "pnpm@11.1.2"
}
