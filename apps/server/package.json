    "tsx": "^4.22.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "bson": "^6.10.4",
    "dotenv": "^17.2.2",
    "hono": "^4.12.18",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "openid-client": "^6.8.0",
    "winston": "^3.17.0",
    "zod": "^4.1.11"
